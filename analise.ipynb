import pandas as pd

# Criando um dataset de exemplo para o recrutador ver seu raciocínio
data = {
    'Pais': ['Finlândia', 'Dinamarca', 'Suíça', 'Brasil', 'EUA'],
    'PIB_per_Capita': [1.44, 1.50, 1.56, 1.06, 1.53],
    'Felicidade': [7.84, 7.62, 7.57, 6.33, 6.95],
    'Corrupcao': [0.48, 0.48, 0.42, 0.08, 0.22]
}

df = pd.DataFrame(data)

# Criando a métrica Sênior: Eficiência (Felicidade por PIB)
df['Eficiencia'] = df['Felicidade'] / df['PIB_per_Capita']

print("--- Análise de Eficiência de Felicidade ---")
print(df.sort_values(by='Eficiencia', ascending=False))
